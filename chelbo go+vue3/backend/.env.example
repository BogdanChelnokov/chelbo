# Server
SERVER_PORT=8080
SERVER_HOST=localhost
ENVIRONMENT=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=chelbo
DB_PASSWORD=
DB_NAME=chelbo3
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-key-change-me-in-production
JWT_EXPIRY_HOURS=24

# Files
STORAGE_TYPE=local
STORAGE_PATH=./uploads
MAX_FILE_SIZE_MB=50

# AI
AI_ENABLED=true
AI_MOCK_RESPONSES=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100